# 复制为 deploy.env，填写后 **不要提交**（已在 .gitignore）
# 在仓库根或 infra/whisper 下执行部署脚本前：  source deploy.env   （bash）
# 或逐条 export。

WHISPER_DEPLOY_HOST=你的服务器IP或主机名
WHISPER_DEPLOY_USER=root
WHISPER_REMOTE_DIR=/opt/echoon-whisper

# 可选：仅当已安装 sshpass（常见于 Linux/WSL）且无法使用 SSH 公钥时，在**当前终端**临时：
#   export SSHPASS='你的密码'
# 切勿把密码写进本文件。
