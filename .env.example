# 复制为 .env 后填写真实值（不要提交 .env 到 git）
#
# --- PostgreSQL（使用现有服务器时）---
# 可以新建一个库给本应用用，在 psql 里执行例如：
#   CREATE DATABASE echoon OWNER lourd;
#   GRANT ALL PRIVILEGES ON DATABASE echoon TO lourd;
#
# 连接串格式：postgresql://用户:密码@主机:5432/数据库名?schema=public
# 密码里如有 @ : / 等特殊字符，需要做 URL 编码。
#
# 后端在 Docker 里、数据库在本机时，主机可用 host.docker.internal（Windows/Mac Docker Desktop）
DATABASE_URL=postgresql://lourd:请填写密码@你的服务器IP或host.docker.internal:5432/echoon?schema=public

# --- Redis（和 RabbitMQ 不同：Redis 是缓存/队列常用组件，端口多为 6379）---
# 你服务器上的 Redis：把下面改成真实地址；带密码示例 redis://:密码@主机:6379
# 说明：当前仓库里 Nest 后端尚未读取 REDIS_URL 连 Redis，配好变量后还需在代码里接入（如 Bull/BullMQ）才会真正使用。
REDIS_URL=redis://:请填写密码@你的服务器IP或host.docker.internal:6379

JWT_SECRET=请改成随机长字符串

# --- 浏览器跨域（Docker 生产环境 NODE_ENV=production 时必填）---
# 管理后台前端的「完整 Origin」：协议 + 主机 + 端口，不要尾斜杠。多个用英文逗号分隔。
# 不配或只配 localhost 时，用公网 IP 打开前端会 CORS 失败（登录报 Network Error / 204 OPTIONS）。
FRONTEND_ORIGINS=http://你的公网IP或域名:2605

# better-auth：与浏览器访问后端的地址一致（本仓库后端无 /api/v1 全局前缀时用根地址即可）
BETTER_AUTH_URL=http://你的公网IP或域名:2604
# 生产务必改为随机长串（≥32 字符）
BETTER_AUTH_SECRET=请改成随机长字符串至少32位

# 构建前端镜像时注入（须为浏览器能访问到的地址，与上面端口一致）
# 当前后端路由在根路径（如 /auth/login、/admin/users），不要强行加 /api/v1，除非你真的挂了该前缀。
VITE_SERVER_URL=http://你的公网IP或域名:2604
# 若会话 API 与业务 API 不同源，可单独设；多数情况留空即可
# VITE_AUTH_BASE_URL=

# 仅本机端口映射（与 frp 等转发一致时可不改）
BACKEND_HOST_PORT=2604
FRONTEND_HOST_PORT=2605
CLIENT_HOST_PORT=2606

# --- Whisper（可选）：TTS 未返回词级时间戳（如 MiniMax）时，后端在音频生成成功后 POST 到 whisper-server 补全。
# 完整 URL，须包含路径 /inference。与根目录 docker compose --profile whisper 同栈时示例：
#   WHISPER_INFERENCE_URL=http://whisper:8080/inference
# 本机独立起 infra/whisper 且后端在宿主机运行时示例（默认映射端口 2610）：
#   WHISPER_INFERENCE_URL=http://127.0.0.1:2610/inference
# 不配置则跳过 Whisper，行为与改前一致。
# WHISPER_INFERENCE_URL=
# WHISPER_LANGUAGE=zh
# WHISPER_TIMEOUT_MS=600000
# WHISPER_SPLIT_ON_WORD=false
# 根 compose 的 whisper 服务：模型文件名（位于 whisper-models/ 卷内），默认 ggml-medium.bin
# WHISPER_GGML_MODEL=ggml-medium.bin
# WHISPER_MODELS_HOST_PATH=./whisper-models
# 宿主机端口（容器内 8080）
# WHISPER_HOST_PORT=2610
# 仅本机监听用 127.0.0.1；测试期暴露可设 0.0.0.0（whisper 无鉴权，慎用）
# WHISPER_BIND=127.0.0.1
