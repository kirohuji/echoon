# 复制为 .env 后填写真实值（不要提交 .env 到 git）
#
# --- PostgreSQL（使用现有服务器时）---
# 可以新建一个库给本应用用，在 psql 里执行例如：
#   CREATE DATABASE echoon OWNER lourd;
#   GRANT ALL PRIVILEGES ON DATABASE echoon TO lourd;
#
# 连接串格式：postgresql://用户:密码@主机:5432/数据库名?schema=public
# 密码里如有 @ : / 等特殊字符，需要做 URL 编码。
#
# 后端在 Docker 里、数据库在本机时，主机可用 host.docker.internal（Windows/Mac Docker Desktop）
DATABASE_URL=postgresql://lourd:请填写密码@你的服务器IP或host.docker.internal:5432/echoon?schema=public

# --- Redis（和 RabbitMQ 不同：Redis 是缓存/队列常用组件，端口多为 6379）---
# 你服务器上的 Redis：把下面改成真实地址；带密码示例 redis://:密码@主机:6379
# 说明：当前仓库里 Nest 后端尚未读取 REDIS_URL 连 Redis，配好变量后还需在代码里接入（如 Bull/BullMQ）才会真正使用。
REDIS_URL=redis://:请填写密码@你的服务器IP或host.docker.internal:6379

JWT_SECRET=请改成随机长字符串

# 仅本机端口映射（与 frp 等转发一致时可不改）
BACKEND_HOST_PORT=2604
FRONTEND_HOST_PORT=2605
CLIENT_HOST_PORT=2606
